{
  "name": "sass-lookup",
  "version": "6.1.1",
  "description": "Get the file associated with a Sass import",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "bin/cli.js",
    "index.js"
  ],
  "bin": {
    "sass-lookup": "bin/cli.js"
  },
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "uvu": "uvu test -i fixtures",
    "test": "npm run lint && npm run uvu",
    "test:ci": "c8 npm run uvu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-sass-lookup.git"
  },
  "keywords": [
    "sass",
    "lookup",
    "dependency",
    "import",
    "resolution"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-sass-lookup/issues"
  },
  "homepage": "https://github.com/dependents/node-sass-lookup",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "enhanced-resolve": "^5.20.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "mock-fs": "^5.5.0",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  }
}
